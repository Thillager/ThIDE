<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE theme [
  <!ELEMENT theme (background?, caret?, currentLineHighlight?, marginLine?, markAllHighlight?, matchedBracket?, hyperlinks?, selection?, font?, tokenStyles?)>
  <!ATTLIST theme version CDATA #REQUIRED>
  <!ELEMENT background EMPTY>
  <!ATTLIST background color CDATA #REQUIRED>
  <!ELEMENT caret EMPTY>
  <!ATTLIST caret color CDATA #REQUIRED>
  <!ELEMENT currentLineHighlight EMPTY>
  <!ATTLIST currentLineHighlight color CDATA #REQUIRED fade (true|false) #REQUIRED>
  <!ELEMENT marginLine EMPTY>
  <!ATTLIST marginLine color CDATA #REQUIRED>
  <!ELEMENT markAllHighlight EMPTY>
  <!ATTLIST markAllHighlight color CDATA #REQUIRED>
  <!ELEMENT matchedBracket EMPTY>
  <!ATTLIST matchedBracket color CDATA #REQUIRED bgColor CDATA #REQUIRED>
  <!ELEMENT hyperlinks EMPTY>
  <!ATTLIST hyperlinks color CDATA #REQUIRED>
  <!ELEMENT selection EMPTY>
  <!ATTLIST selection background CDATA #REQUIRED foreground CDATA #REQUIRED>
  <!ELEMENT font EMPTY>
  <!ATTLIST font family CDATA #REQUIRED size CDATA #REQUIRED>
  <!ELEMENT tokenStyles (style*)>
  <!ELEMENT style EMPTY>
  <!ATTLIST style token CDATA #REQUIRED foreground CDATA #REQUIRED bold (true|false) #IMPLIED italic (true|false) #IMPLIED underline (true|false) #IMPLIED>
]>
<theme version="1.0">
   <background color="0d0000"/>
   <caret color="ff3333"/>
   <currentLineHighlight color="1a0505" fade="true"/>
   <marginLine color="3a0a0a"/>
   <markAllHighlight color="5a1010"/>
   <matchedBracket color="ff5555" bgColor="330000"/>
   <hyperlinks color="ff8888"/>
   <selection background="550d0d" foreground="ffcccc"/>
   <font family="Consolas" size="13"/>
   <tokenStyles>
      <!-- Normaler Text / Fallback: hell-rot damit nichts schwarz auf schwarz wird -->
      <style token="IDENTIFIER"                     foreground="ff8888"/>
      <style token="NULL"                            foreground="ff6666"/>
      <style token="WHITESPACE"                      foreground="ff8888"/>

      <!-- Fehler -->
      <style token="ERROR_IDENTIFIER"               foreground="ff2222" bold="true"/>
      <style token="ERROR_NUMBER_FORMAT"             foreground="ff2222" bold="true"/>
      <style token="ERROR_STRING_DOUBLE"             foreground="ff2222" bold="true"/>
      <style token="ERROR_CHAR"                      foreground="ff2222" bold="true"/>

      <!-- Schlüsselwörter -->
      <style token="RESERVED_WORD"                  foreground="ff3333" bold="true"/>
      <style token="RESERVED_WORD_2"                foreground="ff4444" bold="true"/>
      <style token="DATA_TYPE"                       foreground="ff5555" bold="true"/>

      <!-- Literale -->
      <style token="LITERAL_STRING_DOUBLE_QUOTE"    foreground="ffaaaa"/>
      <style token="LITERAL_STRING_SINGLE_QUOTE"    foreground="ffaaaa"/>
      <style token="LITERAL_BACKQUOTE"              foreground="ffaaaa"/>
      <style token="LITERAL_CHAR"                   foreground="ffaaaa"/>
      <style token="LITERAL_NUMBER_DECIMAL_INT"     foreground="ff9999"/>
      <style token="LITERAL_NUMBER_FLOAT"           foreground="ff9999"/>
      <style token="LITERAL_NUMBER_HEXADECIMAL"     foreground="ff9999"/>
      <style token="LITERAL_BOOLEAN"                foreground="ff3333" bold="true"/>

      <!-- Kommentare (etwas dunkler, aber noch sichtbar) -->
      <style token="COMMENT_EOL"                    foreground="993333" italic="true"/>
      <style token="COMMENT_MULTILINE"              foreground="993333" italic="true"/>
      <style token="COMMENT_DOCUMENTATION"          foreground="aa4444" italic="true"/>
      <style token="COMMENT_KEYWORD"                foreground="cc5555" bold="true" italic="true"/>
      <style token="COMMENT_MARKUP"                 foreground="aa4444" italic="true"/>

      <!-- Operatoren & Separatoren -->
      <style token="OPERATOR"                       foreground="ff6666"/>
      <style token="SEPARATOR"                      foreground="ff7777"/>

      <!-- Annotationen, Funktionen, Variablen -->
      <style token="ANNOTATION"                     foreground="ff7777" italic="true"/>
      <style token="FUNCTION"                       foreground="ff8888"/>
      <style token="VARIABLE"                       foreground="ff8888"/>
      <style token="VARIABLE_2"                     foreground="ff9999"/>
      <style token="VARIABLE_3"                     foreground="ff9999"/>
      <style token="PREPROCESSOR"                   foreground="ff5555"/>
      <style token="REGEX"                          foreground="ffaaaa"/>

      <!-- Markup / XML / HTML -->
      <style token="MARKUP_TAG_NAME"                foreground="ff4444" bold="true"/>
      <style token="MARKUP_TAG_ATTRIBUTE"           foreground="ff7777"/>
      <style token="MARKUP_TAG_ATTRIBUTE_VALUE"     foreground="ffaaaa"/>
      <style token="MARKUP_COMMENT"                 foreground="993333" italic="true"/>
      <style token="MARKUP_CDATA"                   foreground="ff8888"/>
      <style token="MARKUP_CDATA_DELIMITER"         foreground="ff5555"/>
      <style token="MARKUP_DTD"                     foreground="cc4444"/>
      <style token="MARKUP_ENTITY_REFERENCE"        foreground="ff7777"/>
      <style token="MARKUP_PROCESSING_INSTRUCTION"  foreground="ff5555"/>
   </tokenStyles>
</theme>
